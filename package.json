{
  "name": "authenticize",
  "version": "1.0.0",
  "description": "Authenticize — personal authentication platform (OIDC provider + admin dashboard) built on Better Auth",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/migrate.ts",
    "auth:generate": "better-auth generate --config src/lib/auth.ts",
    "auth:migrate": "better-auth migrate --config src/lib/auth.ts",
    "apple:secret": "node scripts/apple-client-secret.mjs"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@hono/node-server": "^1.14.0",
    "better-auth": "^1.6.23",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
