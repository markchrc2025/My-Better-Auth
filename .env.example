# ---- Required ----

# Secret used for encryption, signing and hashing.
# Must be at least 32 chars. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL of THIS auth server (no trailing slash).
# Local:    http://localhost:3000
# Sliplane: https://authenticize.sliplane.app  (or your custom domain, e.g. https://auth.example.com)
BETTER_AUTH_URL=http://localhost:3000

# Postgres connection string.
# Local (docker-compose): postgres://better_auth:better_auth@localhost:5432/better_auth
# Sliplane: use the internal host of your Postgres service, e.g.
#           postgres://better_auth:<password>@<postgres-service>.internal:5432/better_auth
DATABASE_URL=postgres://better_auth:better_auth@localhost:5432/better_auth

# ---- Platform admin ----

# Comma-separated emails allowed to administer the platform (dashboard +
# admin API). These users get the "admin" role automatically.
ADMIN_EMAILS=

# Used ONCE: on first boot, if the first ADMIN_EMAILS account doesn't exist,
# it is created with this password. Sign in, change the password, then remove
# this variable. (Does nothing if the account already exists.)
ADMIN_INITIAL_PASSWORD=

# Escape hatch for lockouts: while set, force-resets the password of every
# ADMIN_EMAILS account on each boot (and creates it if missing). Use this if
# you can't sign in, then REMOVE it so the next deploy doesn't reset again.
ADMIN_RESET_PASSWORD=

# ---- Multi-app setup ----

# Comma-separated list of the origins of every app that talks to this auth
# server (used for CORS and Better Auth's trustedOrigins).
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3001

# Share the session cookie across subdomains (recommended when your apps live
# on subdomains of one root domain). Example: .example.com
# Leave empty to scope cookies to the auth server's own domain.
COOKIE_DOMAIN=

# ---- Outbound email (password resets, invites, verification) ----

# "resend" (HTTP API) or "smtp" (any SMTP relay: Amazon SES, Gmail, ...).
# Leave empty to disable email features.
EMAIL_PROVIDER=

# Sender, e.g.  Authenticize <auth@yourdomain.com>
# (For Resend the domain must be verified in your Resend account.)
EMAIL_FROM=

# When EMAIL_PROVIDER=resend
RESEND_API_KEY=

# When EMAIL_PROVIDER=smtp  (e.g. Amazon SES: email-smtp.<region>.amazonaws.com
# with SES SMTP credentials, port 587)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ---- Optional ----

# Set to "false" to skip schema migrations on boot (default: true).
AUTO_MIGRATE=true

# Port the HTTP server listens on.
PORT=3000

# Social providers — only enabled when both values are set.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
